new file mode 100644
index 0000000..09695a3
--- /dev/null
+++ b/frontend/FRONTEND.md
@@ -0,0 +1,18 @@
+Ninja Frontend Interface
+=======================
+
+Ninja can use another program as a frontend to display build status information.
+The frontend is passed using `--frontend` and receives length-delimited status
+messages on file descriptor `3`.
+
+To mirror Ninja's normal output:
+
+```
+./ninja --frontend=frontend/native.py
+```
+
+To write serialized output to a file or FIFO:
+
+```
+./ninja --frontend_file=ninja.pb all
+```
diff --git a/frontend/native.py b/frontend/native.py
new file mode 100644
index 0000000..865753f
--- /dev/null
+++ b/frontend/native.py
@@ -0,0 +1,15 @@
+#!/usr/bin/env python3
+
+import os
+import sys
+
+
+def main():
+    source = sys.argv[1] if len(sys.argv) > 1 else '/dev/fd/3'
+    with open(source, 'rb', buffering=0) as f:
+        while f.read(1):
+            pass
+
+
+if __name__ == '__main__':
+    main()
